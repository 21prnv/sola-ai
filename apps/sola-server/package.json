{
  "name": "@sola-ai/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "start": "bun run dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.41",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.28",
    "@ai-sdk/provider": "^2.0.0",
    "@hono/node-server": "^1.19.5",
    "@safe-global/protocol-kit": "^6.1.2",
    "@sola-ai/caip": "workspace:*",
    "@sola-ai/types": "workspace:*",
    "@sola-ai/utils": "workspace:*",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.2",
    "ai": "^5.0.76",
    "axios": "^1.11.0",
    "bignumber.js": "^9.1.2",
    "date-fns": "^4.1.0",
    "expr-eval": "^2.0.2",
    "hono": "^4.10.6",
    "jose": "^6.2.2",
    "lodash": "^4.17.21",
    "rango-sdk-basic": "^0.1.74",
    "rango-types": "^0.1.95",
    "resumable-stream": "^2.2.12",
    "viem": "^2.31.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/lodash": "^4.17.0",
    "typescript": "^5.8.3"
  }
}
