      "import": "./src/assetData/*.json",
      "default": "./src/assetData/*.json"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@sola-ai/caip": "workspace:*",
    "@sola-ai/types": "workspace:*",
    "bignumber.js": "^9.1.2",
    "viem": "^2.31.0"
  }
}
