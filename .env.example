# =========================================================================
# Sola-AI environment variables
# Copy this file to `.env` and fill in your values.
# Vite loads from repo root via `envDir` — one file serves both apps.
# =========================================================================

# -------------------------------------------------------------------------
# AI provider
# -------------------------------------------------------------------------
# "openai" (default) or "venice"
AI_PROVIDER=openai

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=
# Optional model override (default: gpt-3.5-turbo)
OPENAI_MODEL=

# Anthropic (optional — used when routing to Claude)
ANTHROPIC_API_KEY=

# Venice (required when AI_PROVIDER=venice)
VENICE_API_KEY=

# -------------------------------------------------------------------------
# Wallet connect
# -------------------------------------------------------------------------
# Dynamic Labs environment ID.
# Used by the client to initialise Dynamic AND by the server to verify the
# JWTs Dynamic issues (server fetches the tenant JWKS and requires every
# chat request to carry a valid Bearer token signed by this environment).
VITE_DYNAMIC_ENVIRONMENT_ID=

# -------------------------------------------------------------------------
# Market data
# -------------------------------------------------------------------------
# CoinGecko Pro API key
COINGECKO_API_KEY=

# -------------------------------------------------------------------------
# Swaps (Rango)
# -------------------------------------------------------------------------
# Rango Basic API key
RANGO_API_KEY=
# Optional: default slippage percent (default 1.5)
# RANGO_SLIPPAGE_PERCENT=
# Optional: meta() cache TTL in ms (default 3600000 = 1h)
# RANGO_META_CACHE_MS=

# -------------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------------
PORT=8787

# Frontend → backend URL (used by ChatProvider / portfolio client)
VITE_AGENTIC_SERVER_BASE_URL=
# Or:
# VITE_API_URL=

# -------------------------------------------------------------------------
# Blockchain read endpoints (per-chain HTTP APIs)
# -------------------------------------------------------------------------
ETHEREUM_HTTP_URL=
AVALANCHE_HTTP_URL=
OPTIMISM_HTTP_URL=
BNBSMARTCHAIN_HTTP_URL=
POLYGON_HTTP_URL=
GNOSIS_HTTP_URL=
ARBITRUM_HTTP_URL=
ARBITRUM_NOVA_HTTP_URL=
BASE_HTTP_URL=
SOLANA_HTTP_URL=

# -------------------------------------------------------------------------
# RPC endpoints (VITE_ prefix required for client access)
# -------------------------------------------------------------------------
VITE_ETHEREUM_NODE_URL=
VITE_AVALANCHE_NODE_URL=
VITE_OPTIMISM_NODE_URL=
VITE_BNBSMARTCHAIN_NODE_URL=
VITE_POLYGON_NODE_URL=
VITE_GNOSIS_NODE_URL=
VITE_ARBITRUM_NODE_URL=
VITE_BASE_NODE_URL=
VITE_SOLANA_RPC_URL=

# -------------------------------------------------------------------------
# Observability (optional)
# -------------------------------------------------------------------------
# Used by CI to upload source maps on push to main
SENTRY_AUTH_TOKEN=
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=
