# =========================================================================
# Sola-AI environment variables
# Copy this file to `.env` and fill in your values.
# Vite loads from repo root via `envDir` — one file serves both apps.
# =========================================================================

# -------------------------------------------------------------------------
# AI provider
# -------------------------------------------------------------------------
# "openai" (default) or "venice"
AI_PROVIDER=openai

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
# Optional model override (default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional — used when routing to Claude)
ANTHROPIC_API_KEY=

# Venice (required when AI_PROVIDER=venice)
VENICE_API_KEY=

# -------------------------------------------------------------------------
# Wallet connect
# -------------------------------------------------------------------------
# Dynamic Labs project ID — https://www.dynamic.xyz/
VITE_DYNAMIC_ENVIRONMENT_ID=

# -------------------------------------------------------------------------
# Market data
# -------------------------------------------------------------------------
# CoinGecko Pro API key — https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# -------------------------------------------------------------------------
# Swaps (Rango)
# -------------------------------------------------------------------------
# Rango Basic API key — https://docs.rango.exchange/api-integration/basic-api-single-step
RANGO_API_KEY=
# Optional: default slippage percent (default 1.5)
# RANGO_SLIPPAGE_PERCENT=1.5
# Optional: meta() cache TTL in ms (default 3600000 = 1h)
# RANGO_META_CACHE_MS=3600000

# -------------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------------
PORT=8787

# Frontend → backend URL (used by ChatProvider / portfolio client)
VITE_AGENTIC_SERVER_BASE_URL=http://localhost:8787
# Or:
# VITE_API_URL=http://localhost:8787

# -------------------------------------------------------------------------
# Blockchain read endpoints (per-chain HTTP APIs)
# -------------------------------------------------------------------------
ETHEREUM_HTTP_URL=https://dev-api.ethereum.shapeshift.com
AVALANCHE_HTTP_URL=https://dev-api.avalanche.shapeshift.com
OPTIMISM_HTTP_URL=https://dev-api.optimism.shapeshift.com
BNBSMARTCHAIN_HTTP_URL=https://dev-api.bnbsmartchain.shapeshift.com
POLYGON_HTTP_URL=https://dev-api.polygon.shapeshift.com
GNOSIS_HTTP_URL=https://dev-api.gnosis.shapeshift.com
ARBITRUM_HTTP_URL=https://dev-api.arbitrum.shapeshift.com
ARBITRUM_NOVA_HTTP_URL=https://dev-api.arbitrum-nova.shapeshift.com
BASE_HTTP_URL=https://dev-api.base.shapeshift.com
SOLANA_HTTP_URL=https://dev-api.solana.shapeshift.com

# -------------------------------------------------------------------------
# RPC endpoints (VITE_ prefix required for client access)
# -------------------------------------------------------------------------
VITE_ETHEREUM_NODE_URL=https://api.ethereum.shapeshift.com/api/v1/jsonrpc
VITE_AVALANCHE_NODE_URL=https://api.avalanche.shapeshift.com/api/v1/jsonrpc
VITE_OPTIMISM_NODE_URL=https://api.optimism.shapeshift.com/api/v1/jsonrpc
VITE_BNBSMARTCHAIN_NODE_URL=https://api.bnbsmartchain.shapeshift.com/api/v1/jsonrpc
VITE_POLYGON_NODE_URL=https://api.polygon.shapeshift.com/api/v1/jsonrpc
VITE_GNOSIS_NODE_URL=https://daemon.gnosis.shapeshift.com
VITE_ARBITRUM_NODE_URL=https://api.arbitrum.shapeshift.com/api/v1/jsonrpc
VITE_BASE_NODE_URL=https://api.base.shapeshift.com/api/v1/jsonrpc
VITE_SOLANA_RPC_URL=https://api.solana.shapeshift.com/api/v1/jsonrpc

# -------------------------------------------------------------------------
# Observability (optional)
# -------------------------------------------------------------------------
# Used by CI to upload source maps on push to main
SENTRY_AUTH_TOKEN=
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=
