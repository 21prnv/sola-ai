{
  "name": "sola-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.2"
  },
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist",
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"bun run --filter @sola-ai/frontend dev\" \"bun run --filter @sola-ai/server dev\"",
    "dev:frontend": "bun run --filter @sola-ai/frontend dev",
    "dev:backend": "bun run --filter @sola-ai/server dev",
    "build": "bun run --filter @sola-ai/frontend build && bun run --filter @sola-ai/server build",
    "type-check": "bun run --filter '*' type-check",
    "test": "bun run --filter @sola-ai/server test && bun run --filter @sola-ai/frontend test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "overrides": {
    "@solana/web3.js": "1.98.4"
  }
}
